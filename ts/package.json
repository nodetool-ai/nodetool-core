{
  "name": "nodetool-workflow-ts",
  "private": true,
  "workspaces": [
    "packages/protocol",
    "packages/kernel",
    "packages/runtime",
    "packages/models",
    "packages/node-sdk",
    "packages/base-nodes",
    "packages/parity-harness",
    "packages/websocket",
    "packages/agents",
    "packages/chat",
    "packages/security",
    "packages/auth",
    "packages/cli",
    "packages/storage",
    "packages/config"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "metadata-parity": "npm run test:metadata --workspace @nodetool/node-sdk && npm run test:metadata-parity --workspace @nodetool/base-nodes",
    "dev": "npm run dev --workspace @nodetool/websocket",
    "devserver": "npm run devserver --workspace @nodetool/websocket",
    "lint": "eslint packages/*/src packages/*/tests",
    "workflow": "node ./scripts/run-workflow.mjs",
    "chat": "node ./packages/cli/dist/index.js",
    "nodetool": "node ./packages/cli/dist/nodetool.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.0.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "keytar": "^7.9.0"
  }
}
